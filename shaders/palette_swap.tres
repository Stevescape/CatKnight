[sub_resource type="VisualShaderNodeExpression" id="VisualShaderNodeExpression_1hk0m"]
size = Vector2(680, 540)
expression = "vec2 new_uv = vec2(0, 0);

for (int i = 0; i < color_count; i++) {
	float u = (float(i) + 0.5) / float(color_count);
	float v = 0.5;
	vec2 uv = vec2(u, v);
	vec4 og_palette_color = texture(original_palette, uv);
	float dist = distance(color, og_palette_color);
	
	if (dist == 0.0) {
		new_uv = uv;
		break;
	}
}

new_color = texture(new_palette, new_uv);"

